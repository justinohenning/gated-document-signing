<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Serve existing files/dirs at project root as-is (if any).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Route everything else into public/ (visitor app + assets).
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
